// Agent Cockpit — 4-pane Zellij layout for monitor 2.
//   top row:    Claude orchestrate | Claude code
//   bottom row: razernode (completion worker) | NVIDIA (agentic worker)
//
// Panes inherit the directory you launch `cockpit` from.
// Commands rely on PATH (claude, opencode) — the cockpit launches from your
// interactive shell, so ~/.zshrc env (incl. NVIDIA_API_KEY) is inherited.

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="cockpit" focus=true {
        pane split_direction="horizontal" {
            // top row — Claude (coordinator + coder)
            // Launch via an interactive login shell, not as a bare command:
            // Claude renders its TUI inline (no alt-screen) and needs the
            // shell-initialized terminal — a direct `command "claude"` shows
            // only the MCP banner and never paints the UI inside zellij.
            //
            // VERSION PIN (2026-06-02): claude 2.1.161 (released today) regressed
            // this same inline render inside zellij — the pane shows only the MCP
            // banner and never paints, in BOTH WezTerm and Ghostty. 2.1.157–2.1.159
            // rendered fine, so we pin to a known-good build via ${COCKPIT_CLAUDE}.
            // Bump/revert when a newer claude fixes zellij rendering, e.g.:
            //   COCKPIT_CLAUDE=$(command -v claude) cockpit --fresh
            // or just edit the default version below.
            pane split_direction="vertical" {
                pane name="claude-orchestrate" focus=true {
                    // `cd ~/cockpit` so Claude reliably auto-loads the dispatch protocol
                    // (~/cockpit/CLAUDE.md). The zellij `cwd=` attribute proved unreliable, so
                    // we force it in the shell — otherwise the pane thinks cockpit-ask is a
                    // missing sub-agent instead of a Bash command.
                    command "zsh"
                    args "-ilc" "cd ~/cockpit && ${COCKPIT_CLAUDE:-$HOME/.local/share/claude/versions/2.1.160} --strict-mcp-config --mcp-config ~/Desktop/claude/agent-cockpit/mcp/cockpit.mcp.json"
                }
                pane name="claude-code" {
                    command "zsh"
                    args "-ilc" "${COCKPIT_CLAUDE:-$HOME/.local/share/claude/versions/2.1.160} --strict-mcp-config --mcp-config ~/Desktop/claude/agent-cockpit/mcp/cockpit.mcp.json"
                }
            }
            // bottom row — workers
            pane split_direction="vertical" {
                pane name="razernode-completion" {
                    command "opencode"
                    args "-m" "razernode/qwen2.5-coder-32k:latest"
                }
                pane name="agentic" {
                    // free + reliable agent (bake-off winner); matches cockpit-agent's default.
                    // escalate to a metered model by hand when needed, e.g.
                    //   opencode -m nvidia/moonshotai/kimi-k2-instruct
                    command "opencode"
                    args "-m" "opencode/big-pickle"
                }
            }
        }
    }
}
